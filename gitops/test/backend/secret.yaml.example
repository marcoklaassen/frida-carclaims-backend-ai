# Do not commit real secrets. Create the secret in the cluster instead:
#
#   oc create secret generic voice-backend-secrets -n frida-carclaims-test \
#     --from-literal=LITELLM_API_KEY='sk-...'
#
# Optional — only if your Whisper endpoint requires authentication:
#     --from-literal=WHISPER_API_KEY='...'
#
# Or apply this file locally after replacing placeholders (keep out of git):
#
# apiVersion: v1
# kind: Secret
# metadata:
#   name: voice-backend-secrets
#   namespace: frida-carclaims-test
# type: Opaque
# stringData:
#   LITELLM_API_KEY: "replace-me"
#   WHISPER_API_KEY: ""
